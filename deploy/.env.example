SUB2API_BASE_URL=http://127.0.0.1:8080
HOST=0.0.0.0
PORT=80
STATIC_DIR=dist

DATABASE_URL=postgres://image:image_password@127.0.0.1:5433/image_studio?sslmode=disable
REDIS_URL=redis://127.0.0.1:6380/0
APP_SECRET=change-this-to-a-long-random-secret

ASSET_TTL_SECONDS=86400
DELETE_ASSETS_ON_ACK=true

IMAGE_WORKER_COUNT=2
AGENT_WORKER_COUNT=1
UPSTREAM_TIMEOUT_SECONDS=1800
KEYS_CACHE_TTL_SECONDS=300

MAX_UPLOAD_MB=80
MAX_RESULT_MB=600
MAX_EVENT_BODY_KB=1024

SITE_NAME=链路云
SITE_URL=https://dash.ovload.com
SITE_ICON_URL=/pwa-icon.svg

LEGACY_PROXY_ENABLED=false

# Legacy proxy compatibility knobs. New image generation uses /api/image/jobs.
WORKER_COUNT=2
MAX_CREATE_REQUEST_MB=600
MAX_UPSTREAM_BODY_MB=600
MAX_UPSTREAM_RESULT_MB=600
TASK_TTL_SECONDS=3600
