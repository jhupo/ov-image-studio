# Copy this file to deploy/.env before running docker compose from deploy/.

# Image name/version.
IMAGE_STUDIO_IMAGE=chaincloud-image-studio
IMAGE_STUDIO_TAG=local
IMAGE_STUDIO_CONTAINER_NAME=chaincloud-image-studio
IMAGE_STUDIO_HTTP_PORT=80

# Upstream image API. For the 31 server deployment, set this to the internal Sub2API/OpenAI-compatible endpoint.
DEFAULT_IMAGE_API_URL=http://127.0.0.1:8080/v1

# Internal app services.
IMAGE_STUDIO_PORT=8787
POSTGRES_USER=chaincloud
POSTGRES_PASSWORD=chaincloud
POSTGRES_DB=chaincloud_image_studio
POSTGRES_DSN=postgresql://chaincloud:chaincloud@postgres:5432/chaincloud_image_studio
REDIS_URL=redis://redis:6379/0

# Worker and queue limits.
IMAGE_STUDIO_WORKER_COUNT=2
IMAGE_STUDIO_MAX_CONCURRENT=4
IMAGE_STUDIO_MAX_CONCURRENT_PER_USER=2
IMAGE_STUDIO_MAX_CONCURRENT_PER_KEY=2
IMAGE_STUDIO_MAX_CONCURRENT_PER_PROFILE=2

# Redis payload/result/cancel lifetimes.
IMAGE_STUDIO_PAYLOAD_TTL_SECONDS=86400
IMAGE_STUDIO_RESULT_TTL_SECONDS=86400
IMAGE_STUDIO_CANCEL_TTL_SECONDS=3600

# Metadata cleanup.
IMAGE_STUDIO_TASK_METADATA_TTL_SECONDS=604800
IMAGE_STUDIO_CLEANUP_INTERVAL_SECONDS=3600
